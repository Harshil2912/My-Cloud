# =============================================================================
# NAS Cloud Server — Backend Environment Variables (.env.example)
# Copy this file to .env and fill in all required values.
# Never commit .env to version control.
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Node environment
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────
PORT=3443
HOST=0.0.0.0

# ─────────────────────────────────────────────────────────────────────────────
# TLS (HTTPS)
# Generate with: npm run generate-cert [LAN-IP]
# ─────────────────────────────────────────────────────────────────────────────
TLS_CERT_PATH=./certs/server.crt
TLS_KEY_PATH=./certs/server.key

# ─────────────────────────────────────────────────────────────────────────────
# JWT (RS256 asymmetric)
# Generate with: npm run generate-keys
# ─────────────────────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./certs/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./certs/jwt-public.pem
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─────────────────────────────────────────────────────────────────────────────
# Encryption
# Master key: 64 hex characters (256-bit). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────────────────────────────────────────
ENCRYPTION_MASTER_KEY=REPLACE_WITH_64_HEX_CHARS_EXACTLY

# ─────────────────────────────────────────────────────────────────────────────
# Data directories
# ─────────────────────────────────────────────────────────────────────────────
DATA_DIR=./data
BACKUP_DIR=./backups

# ─────────────────────────────────────────────────────────────────────────────
# Upload limits
# ─────────────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_BYTES=5368709120
# Per-user disk quota in bytes (default: 50 GB)
USER_QUOTA_BYTES=53687091200
# Disk safety threshold — reject uploads when free space is below this (bytes)
# Default: 500 MB
DISK_MIN_FREE_BYTES=524288000

# ─────────────────────────────────────────────────────────────────────────────
# Upload abuse limits (v3.0)
# ─────────────────────────────────────────────────────────────────────────────
UPLOAD_HOURLY_LIMIT_BYTES=5368709120
UPLOAD_DAILY_LIMIT_BYTES=21474836480
UPLOAD_TOTAL_LIMIT_BYTES=53687091200

# ─────────────────────────────────────────────────────────────────────────────
# CORS (comma-separated allowed origins)
# ─────────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://192.168.1.100:5173,https://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# Rate limits (requests per window)
# ─────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_GLOBAL_MAX=200
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_UPLOAD_MAX=50
RATE_LIMIT_REGISTER_MAX=5

# ─────────────────────────────────────────────────────────────────────────────
# Brute force lockout
# ─────────────────────────────────────────────────────────────────────────────
# Number of failed logins before temporary lockout
BRUTE_FORCE_MAX_ATTEMPTS=10
# Lock duration in minutes
BRUTE_FORCE_LOCK_MINUTES=15
# Account hard-lock threshold (permanent until admin resets)
BRUTE_FORCE_HARD_LOCK_THRESHOLD=50

# ─────────────────────────────────────────────────────────────────────────────
# Email verification (v3.0)
# Set EMAIL_VERIFICATION_REQUIRED=true to require email confirmation on register
# ─────────────────────────────────────────────────────────────────────────────
EMAIL_VERIFICATION_REQUIRED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@your-domain.com

# Base URL used in verification links sent via email
APP_BASE_URL=https://192.168.1.100:3443

# ─────────────────────────────────────────────────────────────────────────────
# Backup schedule (cron syntax)
# ─────────────────────────────────────────────────────────────────────────────
# DB snapshot daily at 02:00
BACKUP_DB_CRON=0 2 * * *
# File archive weekly on Sunday at 03:00
BACKUP_FILES_CRON=0 3 * * 0
# How many DB snapshots to keep
BACKUP_DB_KEEP=7
# How many file archives to keep
BACKUP_FILES_KEEP=4

# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=./logs/server.log

# ─────────────────────────────────────────────────────────────────────────────
# Cache settings
# ─────────────────────────────────────────────────────────────────────────────
# In-memory LRU stream cache max size in bytes (default: 80 MB)
CACHE_STREAM_MAX_BYTES=83886080
# Metadata cache TTL in seconds
CACHE_METADATA_TTL_SECONDS=300

# ─────────────────────────────────────────────────────────────────────────────
# Compression worker
# ─────────────────────────────────────────────────────────────────────────────
# Poll interval for compression task queue in milliseconds
COMPRESSION_QUEUE_POLL_MS=5000
# Max compression attempts before marking as failed
COMPRESSION_MAX_ATTEMPTS=3

# ─────────────────────────────────────────────────────────────────────────────
# Trust proxy (set to 1 if behind Nginx/Caddy reverse proxy)
# ─────────────────────────────────────────────────────────────────────────────
TRUST_PROXY=0
