# =============================================================================
# NAS Cloud Server — .gitignore
# =============================================================================

# ─── Secrets & Certs ─────────────────────────────────────────────────────────
backend/.env
certs/
**/*.pem
**/*.key
**/*.p12
**/*.pfx

# ─── Data directories (uploaded files, database, backups) ────────────────────
data/
backups/
logs/

# ─── Node.js ─────────────────────────────────────────────────────────────────
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*
.npm/
.yarn/

# ─── Build output ────────────────────────────────────────────────────────────
dist/
build/
.vite/

# ─── OS files ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Editor / IDE ────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.user
*.swp
*.swo
*~

# ─── SQLite runtime files ────────────────────────────────────────────────────
*.sqlite-shm
*.sqlite-wal

# ─── Test / Coverage ─────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Misc ────────────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
.env.local
.env.development.local
.env.test.local
.env.production.local
